<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/MainMenu.uss?fileID=7433441132597879392&amp;guid=4c8c9356c3d858c48bdea60c0f54bed2&amp;type=3#MainMenu" />
    <ui:VisualElement name="root" class="root">
        <ui:VisualElement name="bg-base" class="bg-base" />
        <ui:VisualElement name="bg-portal-aura" class="bg-portal-aura" />
        <ui:VisualElement name="bg-portal-aura-2" class="bg-portal-aura-2" />
