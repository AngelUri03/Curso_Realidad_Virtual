            <ui:VisualElement name="main-card" class="main-card">
                <ui:VisualElement name="hero-block" class="hero-block">
                    <ui:VisualElement name="hero-image-frame" class="hero-image-frame">
                        <ui:VisualElement name="hero-image-glow-back" class="hero-image-glow-back" />
